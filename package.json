{
  "name": "estatewise-ai-chatbot",
  "version": "1.1.0",
  "description": "Your Intelligent Estate Assistant providing personalized property recommendations in Chapel Hill.",
  "main": "dist/index.js",
  "author": "Son Nguyen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hoangsonww/AI-Assistant-Chatbot.git"
  },
  "keywords": [
    "real-estate",
    "chatbot",
    "ai",
    "assistant",
    "estate",
    "home",
    "property",
    "apartment",
    "recommendation"
  ],
  "bugs": {
    "url": "https://github.com/hoangsonww/AI-Assistant-Chatbot/issues"
  },
  "scripts": {
    "build": "cd backend && npm run build && cd ../frontend && npm run build && cd ../agentic-ai && npm run build && cd ../mcp && npm run build",
    "start": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run frontend\" \"npm run backend\"",
    "test": "cd backend && npm test && cd ../frontend && npm test && cd ../agentic-ai && npm test && cd ../mcp && npm test && cd ../context-engineering && npm test",
    "frontend": "cd frontend && npm run dev",
    "backend": "cd backend && npm start",
    "context": "cd context-engineering && npm run dev",
    "context:build": "cd context-engineering && npm run build",
    "context:seed": "cd context-engineering && npm run seed",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,scss,html,mdx}\"",
    "lint": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,scss,html,mdx}\"",
    "store": "cd backend && ts-node src/scripts/upsertProperties.ts",
    "jsdoc": "jsdoc -c jsdoc.json",
    "typedoc:backend": "typedoc --tsconfig backend/tsconfig.json backend/src --out docs-backend --entryPointStrategy expand",
    "typedoc:frontend": "typedoc --tsconfig frontend/tsconfig.json frontend --out docs-frontend --entryPointStrategy expand"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.4.2"
  },
  "private": false,
  "devDependencies": {
    "jsdoc": "^4.0.4",
    "typedoc": "^0.28.7"
  }
}
