# MCP server environment
# Copy to .env and adjust if needed

# EstateWise backend base URL
API_BASE_URL=https://estatewise-backend.vercel.app

# EstateWise frontend base URL (used for map deep links)
FRONTEND_BASE_URL=https://estatewise.vercel.app

# Agentic AI A2A base URL for a2a.* tools
A2A_BASE_URL=http://localhost:4318
# Request timeout (ms) for A2A calls
A2A_TIMEOUT_MS=15000
# Poll interval (ms) for fallback wait mode
A2A_POLL_MS=1000
# Default max wait time (ms) when awaiting task completion
A2A_WAIT_TIMEOUT_MS=120000

# Timeout (ms) for outbound web.search/web.fetch requests
WEB_TIMEOUT_MS=12000
# Local Zillow live snapshot file path for live.zillow.search
LIVE_ZILLOW_SNAPSHOT_PATH=../data/live-zillow/output/live_zillow_snapshot.normalized.json
# Max returned rows from live.zillow.search
LIVE_ZILLOW_MAX_RESULTS=25
# Snapshot stale warning threshold in hours
LIVE_ZILLOW_STALE_HOURS=72
# Default minimum listing quality score filter (0-1) for live.zillow.search
LIVE_ZILLOW_MIN_QUALITY_SCORE=0

# MCP server tuning
# TTL (ms) for cached GET responses
MCP_CACHE_TTL_MS=30000
# Max entries in the in-memory LRU cache
MCP_CACHE_MAX=200
# Enable verbose debug logs (true/false)
MCP_DEBUG=false
# Optional server identity override
MCP_SERVER_NAME=estatewise-mcp
MCP_SERVER_VERSION=0.2.0
# Tool governance
MCP_TOOL_TIMEOUT_MS=30000
MCP_TOOL_MAX_ARG_BYTES=65536
MCP_TOOL_MAX_CONCURRENT=32
# Optional CSV allow/deny controls (tool names)
MCP_TOOL_ALLOWLIST=
MCP_TOOL_DENYLIST=

# MCP Token Configuration
# Secret key for signing tokens (recommended: use a strong random value in production)
MCP_TOKEN_SECRET=your-secret-key-here-change-in-production
# Require MCP_TOKEN_SECRET to be set; disallows ephemeral fallback secret
MCP_TOKEN_REQUIRE_SECRET=false
# Optional path to persist token state across restarts
MCP_TOKEN_PERSIST_PATH=
# Access token TTL in milliseconds (default: 1 hour = 3600000ms)
MCP_TOKEN_TTL_MS=3600000
# Refresh token TTL in milliseconds (default: 30 days = 2592000000ms)
MCP_REFRESH_TOKEN_TTL_MS=2592000000
