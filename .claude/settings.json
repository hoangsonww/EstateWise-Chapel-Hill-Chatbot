{
  "mcpServers": {
    "estatewise": {
      "command": "npx",
      "args": ["tsx", "mcp/src/server.ts"],
      "env": {
        "API_BASE_URL": "https://estatewise-backend.vercel.app"
      }
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-reminder.sh"
          }
        ]
      }
    ]
  }
}
