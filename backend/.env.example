# ─── Core ──────────────────────────────────────────────────────────────────
PORT=3001
MONGO_URI=mongodb://localhost:27017/estatewise
JWT_SECRET=change-me-to-a-long-random-string
NODE_ENV=development

# ─── AI / Vector ───────────────────────────────────────────────────────────
GOOGLE_AI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=estatewise-index
PINECONE_NAMESPACE=

# ─── Optional LLM fallback ─────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Neo4j (graph features — optional) ─────────────────────────────────────
NEO4J_ENABLE=false
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# ─── Passkeys / WebAuthn ───────────────────────────────────────────────────
# RP_ID is the effective domain of the FRONTEND (not this backend). Browsers
# bind credentials to it; rotating it invalidates every existing passkey.
#
#   Local dev:   WEBAUTHN_RP_ID=localhost
#                WEBAUTHN_ORIGINS=http://localhost:3000
#
#   Production:  WEBAUTHN_RP_ID=estatewise.vercel.app
#                WEBAUTHN_ORIGINS=https://estatewise.vercel.app
#
# WEBAUTHN_ORIGINS accepts a comma-separated list. Each value must include
# scheme + host (and port if non-default). Wildcards are NOT supported —
# Vercel preview URLs cannot use prod passkeys.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=EstateWise
WEBAUTHN_ORIGINS=http://localhost:3000

# ─── Live data snapshot (optional) ─────────────────────────────────────────
LIVE_ZILLOW_SNAPSHOT_PATH=

# ─── Pinecone -> Neo4j ingest tuning (optional) ────────────────────────────
INGEST_LIMIT=
PINECONE_PAGE_SIZE=1000
INGEST_RESUME=true
PINECONE_START_TOKEN=
INGEST_CHECKPOINT_FILE=
NEO4J_RESET=
NEO4J_WRITE_RETRIES=7
